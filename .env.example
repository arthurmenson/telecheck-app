# Telecheck app local environment template
# Copy to .env and populate. .env is git-ignored.
#
# IMPORTANT: never commit real secrets. The pre-write secret scanner hook
# (per EHBG §13) will block any file containing API keys / tokens / passwords.

# ============================================================
# Server
# ============================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Logger redaction: pino redacts these paths from logs (per AUDIT_EVENTS v5.2 PHI handling)
LOG_REDACT_PATHS=req.headers.authorization,req.body.password,req.body.token

# ============================================================
# Database (PostgreSQL 15+ with RLS per ADR-023)
# ============================================================
DATABASE_URL=postgresql://telecheck:telecheck@localhost:5432/telecheck_dev
# Per-tenant KMS keys (per ADR-024) — local dev uses static keys; prod via AWS KMS
TENANT_KMS_LOCAL_DEV_KEY=dev-only-not-for-production-32-chars

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Spec corpus location
# ============================================================
# If the spec is not at sibling repo ../telecheckONE/, point this at the
# Telecheck Master Bundle FINAL US REGION BASELINE/ directory.
TELECHECK_SPEC_PATH=../telecheckONE/Telecheck Master Bundle FINAL US REGION BASELINE

# ============================================================
# Transactional email delivery (email+PIN passcodes; src/lib/email/)
# ============================================================
# EMAIL_PROVIDER: 'noop' (default) logs + sends nothing — the passcode is still
#   issued/persisted and staging echoes it as dev_passcode. 'resend' sends via
#   https://resend.com (requires RESEND_API_KEY + a verified sending domain
#   matching EMAIL_FROM). See docs/SI-EMAIL-DELIVERY-PROVIDER.md.
EMAIL_PROVIDER=noop
# RESEND_API_KEY: required only when EMAIL_PROVIDER=resend. Store the real key
#   ONLY in the deployment .env / secret store — NEVER commit it.
RESEND_API_KEY=
# EMAIL_FROM: the From header. Domain must be verified in the provider.
EMAIL_FROM=Heros Health <no-reply@heroshealth.com>

# Transactional SMS delivery (phone OTP; src/lib/sms/)
# ============================================================
# SMS_PROVIDER: 'noop' (default) logs + sends nothing — the OTP is still
#   issued/persisted and staging echoes it as dev_otp. 'telnyx' sends via
#   https://telnyx.com (requires TELNYX_API_KEY + a sender: SMS_FROM number OR
#   TELNYX_MESSAGING_PROFILE_ID). See docs/SI-SMS-DELIVERY-PROVIDER.md.
SMS_PROVIDER=noop
# TELNYX_API_KEY: required only when SMS_PROVIDER=telnyx. Store the real key
#   ONLY in the deployment .env / secret store — NEVER commit it.
TELNYX_API_KEY=
# SMS_FROM: sending phone number in E.164 (e.g. +18005550111). Use this OR
#   TELNYX_MESSAGING_PROFILE_ID (a Telnyx profile that picks from a number pool).
SMS_FROM=
TELNYX_MESSAGING_PROFILE_ID=

# AI providers (per ADR-020 multi-provider abstraction)
# ============================================================
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5-20250929

# Resilience: AWS Bedrock + Azure OpenAI (configure if needed)
AWS_BEDROCK_REGION=us-east-1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ============================================================
# AWS (per ADR-026 — us-east-1 primary, us-west-2 cold DR)
# ============================================================
AWS_REGION=us-east-1
AWS_DR_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================
# Tenant identifiers (per Master PRD v1.10 §17 + Glossary v5.2 C3 brand structure)
# Operating-tenant IDs are Telecheck-{country}; never write bare "Heros" here.
# ============================================================
# DEV_DEFAULT_TENANT_ID=Telecheck-US

# Staging/preview hostname → tenant aliases (comma-separated hostname=TenantId).
# Only aliases canonical tenants; DB verification still applies (fail-closed).
# Example (staging VPS, sslip.io wildcard DNS):
# TENANT_HOST_OVERRIDES=87.99.159.214.sslip.io=Telecheck-US,ghana.87.99.159.214.sslip.io=Telecheck-Ghana

# ============================================================
# Feature flags / cycle controls
# ============================================================
# Reserved AI workload types (per WORKLOAD_TAXONOMY v5.2) require successor ADR
# AND activation audit event. These flags should remain false at v1.0.
ENABLE_AUTONOMOUS_AGENT=false
ENABLE_MULTI_AGENT_SUPERVISOR=false
ENABLE_TOOL_USING_AGENT=false
ENABLE_ACTION_WITH_AUDIT_ONLY=false
ENABLE_FULLY_AUTONOMOUS=false

# Research data partnership (per ADR-028) — Stage 2 activation gate
# Set to "active" only after ADR-028 quad sign-off + Country Launch Director + REC concurrence
RESEARCH_DATA_PARTNERSHIP_ACTIVE=inactive

# Mode 2 case-prep route mount gate (per Codex PR #210 R1 NEEDS-WORK closure).
# Default OFF. Flip to "true" only after ALL THREE Day-3+ prerequisites land:
#   1. clinical-anchor authorization (clinician-on-care-team-for-named-protocol)
#   2. real protocol-engine provider execution (I-012 reject-unless at prescribing boundary)
#   3. verified audit-emission discipline (I-019 + I-027 end-to-end against live Postgres + real LLM provider)
# Production MUST keep this "false" until all three land.
AI_MODE2_ENABLED=false
