# Caddy reverse proxy — automatic HTTPS via Let's Encrypt.
# STAGING_DOMAINS + ACME_EMAIL come from infra/staging/.env via compose.
# STAGING_DOMAINS may be multiple comma-separated hosts (placeholder is
# expanded before address parsing) — one cert per host, same site config.

{$STAGING_DOMAINS} {
	tls {$ACME_EMAIL}

	# Basic hardening; staging serves synthetic data only, but the posture
	# should match production habits.
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}

	reverse_proxy app:3000
}

# Patient app (Track 4) — static Expo web export served from the host
# directory mounted at /srv/patient-app (see docker-compose.yml caddy
# volumes). Mock-backed at this stage: the app's TelecheckApi interface
# is satisfied by src/api/mock; the real HTTP client swap-in is the
# recorded Track-4 follow-on. SPA fallback via try_files (client-side
# routing). No X-Frame-Options DENY here — the app is a UI, not an API.
{$PATIENT_APP_DOMAIN} {
	tls {$ACME_EMAIL}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		-Server
	}

	# Same-origin API proxy: the app's fetches go to THIS host (the API
	# has no CORS surface — deliberate; same-origin avoids opening one).
	# Tenant resolution works because TENANT_HOST_OVERRIDES maps this
	# host to Telecheck-US in infra/staging/.env.
	handle /v0/* {
		reverse_proxy app:3000
	}
	handle /v1/* {
		reverse_proxy app:3000
	}
	handle /health {
		reverse_proxy app:3000
	}

	# Everything else: the static Expo web export (SPA fallback).
	handle {
		root * /srv/patient-app
		try_files {path} /index.html
		file_server
	}
}

# Admin / clinician console (Track 4, SI-025 Phase 2) — static Vite web
# build served from the host directory mounted at /srv/admin-console (see
# docker-compose.yml caddy volumes). Real-API-backed: the console's
# VITE_API_MODE=real HTTP client fetches this SAME host (same-origin, no
# CORS surface). Tenant resolution works because TENANT_HOST_OVERRIDES maps
# this host to Telecheck-US in infra/staging/.env — mirrors the patient
# host block above. SPA fallback via try_files (client-side routing).
{$ADMIN_APP_DOMAIN} {
	tls {$ACME_EMAIL}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		-Server
	}

	# Same-origin API proxy: the console's fetches go to THIS host. An
	# unmapped Host fails closed at tenant resolution (by design), so the
	# admin host MUST be in TENANT_HOST_OVERRIDES=admin.<host>=Telecheck-US.
	handle /v0/* {
		reverse_proxy app:3000
	}
	handle /v1/* {
		reverse_proxy app:3000
	}
	handle /health {
		reverse_proxy app:3000
	}

	# Everything else: the static Vite web build (SPA fallback).
	handle {
		root * /srv/admin-console
		try_files {path} /index.html
		file_server
	}
}
