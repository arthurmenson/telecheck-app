# Caddy reverse proxy — automatic HTTPS via Let's Encrypt.
# STAGING_DOMAINS + ACME_EMAIL come from infra/staging/.env via compose.
# STAGING_DOMAINS may be multiple comma-separated hosts (placeholder is
# expanded before address parsing) — one cert per host, same site config.

{$STAGING_DOMAINS} {
	tls {$ACME_EMAIL}

	# Basic hardening; staging serves synthetic data only, but the posture
	# should match production habits.
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}

	reverse_proxy app:3000
}
