# Telecheck staging environment — copy to infra/staging/.env and fill in.
# infra/staging/.env is gitignored; NEVER commit real values (secrets
# discipline: credentials live only on the VPS / in the operator vault).

# --- Postgres (compose-internal) ---
POSTGRES_DB=telecheck
POSTGRES_USER=telecheck
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM

# --- TLS / domain ---
# Point an A record for this hostname at the VPS IP before first boot;
# Caddy provisions the Let's Encrypt cert automatically.
STAGING_DOMAIN=staging.example.com
ACME_EMAIL=ops@example.com

# --- App secrets (extend as slices require; see .env.example at repo root
#     for the full application variable inventory) ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM
# AI providers stay OFF/null in staging until keys are provisioned:
# ANTHROPIC_API_KEY=
# AI_MODE2_ENABLED=false
