# Telecheck staging environment — copy to infra/staging/.env and fill in.
# infra/staging/.env is gitignored; NEVER commit real values (secrets
# discipline: credentials live only on the VPS / in the operator vault).
#
# Generate strong values with:  openssl rand -base64 48

# --- Postgres (compose-internal; TLS via pg-init-ssl.sh self-signed) ---
POSTGRES_DB=telecheck
POSTGRES_USER=telecheck
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM

# SI-010 bind-pool role password (deploy.sh runs the post-migration
# ALTER ROLE bind_actor_context_role LOGIN PASSWORD step with this value).
BIND_ROLE_PASSWORD=CHANGE_ME_LONG_RANDOM

# --- TLS / domain ---
# Either a real hostname with an A record at the VPS IP, or the zero-DNS
# fallback <VPS_IP>.sslip.io (provision-hetzner.sh defaults to sslip.io).
STAGING_DOMAIN=staging.example.com
# Multi-host form (one cert per host; Caddy expands the placeholder).
# The FOUR staging hosts: US API, Ghana API, patient app static host, and
# the admin/clinician console static host (SI-025 Phase 2). Every host that
# Caddy must mint a cert for goes in STAGING_DOMAINS.
# STAGING_DOMAINS="<VPS_IP>.sslip.io, ghana.<VPS_IP>.sslip.io, patient.<VPS_IP>.sslip.io, admin.<VPS_IP>.sslip.io"
ACME_EMAIL=ops@example.com

# --- Tenant host mapping (REQUIRED for every host that serves /v0 or /v1) ---
# Codex Phase-D R1 MEDIUM (2026-07-08): a host that proxies /v0,/v1 to the app
# MUST be mapped here or its same-origin API proxy fails closed on tenant
# resolution (an unmapped Host is rejected — fail-closed by design). This
# applies to BOTH the patient host and the SI-025 admin-console host. Keep in
# lockstep with PATIENT_APP_DOMAIN + ADMIN_APP_DOMAIN below.
# TENANT_HOST_OVERRIDES=patient.<VPS_IP>.sslip.io=Telecheck-US,admin.<VPS_IP>.sslip.io=Telecheck-US,<VPS_IP>.sslip.io=Telecheck-US,ghana.<VPS_IP>.sslip.io=Telecheck-Ghana

# --- Patient app static host (Track 4; see STAGING_RUNBOOK "Patient app") ---
# PATIENT_APP_DOMAIN=patient.<VPS_IP>.sslip.io

# --- Admin / clinician console static host (Track 4, SI-025 Phase 2; see
#     STAGING_RUNBOOK "Admin console"). Real-API-backed; the console's
#     same-origin fetches require the admin host in TENANT_HOST_OVERRIDES. ---
# ADMIN_APP_DOMAIN=admin.<VPS_IP>.sslip.io

# --- Staging-only OTP echo (patient-app login while no SMS provider wired;
#     config.ts hard-refuses this when DEPLOY_ENV resolves to production) ---
# AUTH_DEV_OTP_ECHO=true

# --- App production-gate secrets (config.ts fail-closed; each >= 32 chars) ---
JWT_SIGNING_KEY=CHANGE_ME_32_PLUS_CHARS_RANDOM
RESUME_TOKEN_SECRET=CHANGE_ME_32_PLUS_CHARS_RANDOM

# --- KMS (staging uses the local-key path; AWS KMS wiring is pre-go-live) ---
TENANT_KMS_LOCAL_DEV_KEY=CHANGE_ME_32_PLUS_CHARS_RANDOM

# --- AI providers: OFF in staging until keys are provisioned ---
# ANTHROPIC_API_KEY=
AI_MODE2_ENABLED=false
